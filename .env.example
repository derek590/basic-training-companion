# ──────────────────────────────────────────────────────────────────
# Basic Training Companion — environment variables
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# In Vercel, set these under Project → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────

# ── Vercel Postgres ──
# When you connect a Vercel Postgres / Neon database to the project,
# Vercel auto-injects POSTGRES_URL (and friends). Locally, paste the
# pooled connection string from the Storage tab here.
POSTGRES_URL=

# ── Stripe ──
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. Get it from
# https://dashboard.stripe.com/webhooks (or `stripe listen` for local dev).
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (https://dashboard.stripe.com/products).
# Create two prices: a one-time "lifetime" price and a recurring "monthly" price.
STRIPE_PRICE_LIFETIME=price_...
STRIPE_PRICE_MONTHLY=price_...

# ── App ──
# Public origin used to build Stripe success/cancel URLs.
# Local: http://localhost:5173 — Production: https://yourdomain.com
APP_URL=http://localhost:5173
